{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/question", "destination": "/question.html" },
    { "source": "/video", "destination": "/video.html" },
    { "source": "/final", "destination": "/final.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
